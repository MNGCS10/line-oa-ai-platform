# MySQL connection string
DATABASE_URL=mysql://root:root@localhost:3306/line_oa_platform

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000

# Session signing secret — set a long random value in production
JWT_SECRET=change-me-to-a-long-random-string

# Optional: password for the seeded admin user (server/src/db/seed.ts)
SEED_ADMIN_PASSWORD=changeme123

# LINE channel access token/secret and AI provider API keys are NOT set here —
# they are entered via the Settings page and stored in the `system_settings` /
# `ai_providers` tables, per the platform's "never hardcode secrets" rule.
