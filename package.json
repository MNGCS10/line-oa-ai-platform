{
  "name": "line-oa-ai-platform",
  "private": true,
  "version": "1.0.0",
  "description": "LINE OA AI Business Automation Platform — generic template (test case: Baan Dek Pediatric Clinic)",
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "postinstall": "npm run build:shared",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build:shared": "npm run build --workspace=shared",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "build": "npm run build:shared && npm run build:client && npm run build:server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "drizzle-orm": "^0.36.4"
  }
}
